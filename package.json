{
  "name": "prpilot-review",
  "version": "1.0.0",
  "description": "Multi-model consensus AI-powered PR reviewer - Intelligent pull request reviews with automatic consensus from multiple AI models.",
  "author": "Bishal Prasad",
  "main": "dist/index.js",
  "files": [
    "dist",
    "action.yml",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf lib dist",
    "build": "npm run clean && tsc && ncc build lib/index.js -o dist --source-map",
    "lint": "eslint src",
    "format": "prettier --write .",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "release": "changeset version && changeset publish"
  },
  "keywords": [
    "github",
    "github-action",
    "pull-request",
    "ai",
    "gemini",
    "multi-model",
    "consensus",
    "pr-review"
  ],
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@octokit/rest": "^20.1.0",
    "node-fetch": "^2.7.0",
    "undici": "^6.24.0",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/node-fetch": "^2.6.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "husky": "^8.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "^6.24.0"
  }
}
